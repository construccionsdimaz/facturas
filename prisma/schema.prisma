// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL_NON_POOLING")
}

// User represents the company/owner of the app (you and your team)
model User {
  id    String  @id @default(cuid())
  email String  @unique
  name  String?
  role  String  @default("ADMIN") // ADMIN, ACCOUNTANT, etc

  // Company Profile Settings
  companyName     String?
  companyAddress  String?
  companyCity     String?
  companyZip      String?
  companyProvince String?
  companyTaxId    String?
  companyLogo     String?
  logoZoom        Float   @default(1)
  logoX           Float   @default(0)
  logoY           Float   @default(0)
  paymentMethod   String?
  bankAccount     String?
  dataProtection  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients         Client[] // The clients that belong to this user
  invoices        Invoice[]
  estimates       Estimate[]
  projects        Project[]
  companyExpenses CompanyExpense[]
}

// Client represents the people/companies you are billing
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  address   String?
  phone     String?
  taxId     String? // NIF/CIF/DNI/NIE
  category  String   @default("CLIENTE") // CLIENTE, PROVEEDOR, COLABORADOR, SUBCONTRATA, INVERSOR, MIXTO
  subType   String? // PARTICULAR, EMPRESA, PROMOTOR, COMUNIDAD (relevant for CLIENTE/MIXTO)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId          String
  user            User             @relation(fields: [userId], references: [id])
  invoices        Invoice[]
  estimates       Estimate[]
  projects        Project[]
  expenses        ProjectExpense[]
  companyExpenses CompanyExpense[]
  movements       Movement[]
}

// Invoice record
model Invoice {
  id        String    @id @default(cuid())
  number    String    @unique // INV-2026-001
  issueDate DateTime  @default(now())
  dueDate   DateTime?
  status    String    @default("DRAFT") // DRAFT, ISSUED, PARTIAL, PAID, CANCELLED
  isSent    Boolean   @default(false)

  subtotal   Float @default(0)
  taxRate    Float @default(21.0)
  taxAmount  Float @default(0)
  paidAmount Float @default(0)
  total      Float @default(0)

  currency      String  @default("EUR")
  language      String  @default("ES") // ES, CA, EN
  notes         String?
  paymentMethod String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  items InvoiceItem[]

  // Relations to source documents
  certifications ProjectCertification[]
  estimate       Estimate?
  movements      Movement[]
}

// Individual items (concepts) within an invoice
model InvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Int    @default(1)
  price       Float  @default(0)

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// Estimate record (Presupuesto)
model Estimate {
  id         String    @id @default(cuid())
  number     String    @unique // PRE-2026-001
  issueDate  DateTime  @default(now())
  validUntil DateTime?
  status     String    @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED

  subtotal  Float @default(0)
  taxRate   Float @default(21.0)
  taxAmount Float @default(0)
  total     Float @default(0)

  currency String  @default("EUR")
  language String  @default("ES") // ES, CA, EN
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  items EstimateItem[]

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  invoiceId String?  @unique // Link to the invoice if converted
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

// Individual items (concepts) within an estimate
model EstimateItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  price       Float  @default(0)
  unit        String @default("ud") // m2, m3, ud, etc
  chapter     String @default("01 GENERAL")

  estimateId String
  estimate   Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

// Project/Work record (Obra)
model Project {
  id                 String    @id @default(cuid())
  code               String?
  name               String
  projectType        String? // Residencial, Reforma, Obra Civil, etc.
  description        String?
  address            String?
  manager            String? // Responsable principal
  targetEndDate      DateTime?
  contractualEndDate DateTime?
  observations       String?
  setupStatus        String    @default("INCOMPLETE") // INCOMPLETE, IN_PREPARATION, READY_FOR_PLANNING, VALIDATED
  status             String    @default("ACTIVE") // ACTIVE, COMPLETED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  invoices            Invoice[]
  estimates           Estimate[]
  budgetLines         ProjectBudgetLine[]
  expenses            ProjectExpense[]
  certifications      ProjectCertification[]
  logs                ProjectLog[]
  documents           ProjectDocument[]
  imputedExpenses     ImputedExpense[]
  movements           Movement[]
  movementImputations MovementImputation[]

  calendar    ProjectCalendar?
  milestones  ProjectMilestone[]
  constraints ProjectConstraint[]
  locations   ProjectLocation[]
  wbs         ProjectWBS[]
  activities   ProjectActivity[]
  weeklyPlans  WeeklyPlan[]
  restrictions Restriction[]
  supplies     ProjectSupply[]
  baselines    ProjectBaseline[]
  changeRequests ProjectChangeRequest[]
}

model ProjectTypology {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?

  workType    String
  siteType    String
  scopeType   String

  finishLevelDefault     String?
  complexityFactor       Float    @default(1)
  costSensitivity        Float    @default(1)
  timeSensitivity        Float    @default(1)
  operationalSensitivity Float    @default(1)
  status                 String   @default("ACTIVA")

  costItems         TypologyCostItem[]
  locationTemplates TypologyLocationTemplate[]
  activityTemplates TypologyActivityTemplate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TypologyCostItem {
  id         String          @id @default(cuid())
  typologyId String
  typology   ProjectTypology @relation(fields: [typologyId], references: [id], onDelete: Cascade)

  code        String
  chapterCode String
  chapterName String
  name        String
  unit        String
  lineKind    String         @default("DIRECT")
  order       Int            @default(0)
  status      String         @default("ACTIVA")

  inclusionRule   Json?
  measurementRule Json?
  pricingRule     Json?

  standardActivityId String?
  standardActivity   StandardActivity? @relation(fields: [standardActivityId], references: [id], onDelete: SetNull)

  productivityRateId String?
  productivityRate   ProductivityRate? @relation(fields: [productivityRateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([typologyId, code])
}

model TypologyLocationTemplate {
  id         String          @id @default(cuid())
  typologyId String
  typology   ProjectTypology @relation(fields: [typologyId], references: [id], onDelete: Cascade)

  code           String
  name           String
  type           String
  parentCode     String?
  generationMode String        @default("FIXED")
  quantityRule   Json?
  order          Int           @default(0)
  status         String        @default("ACTIVA")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([typologyId, code])
}

model TypologyActivityTemplate {
  id         String          @id @default(cuid())
  typologyId String
  typology   ProjectTypology @relation(fields: [typologyId], references: [id], onDelete: Cascade)

  code           String
  nameOverride   String?
  wbsCode        String?
  locationCode   String?
  costItemCode   String?
  order          Int            @default(0)
  dependencyType String         @default("FS")
  lagDays        Float          @default(0)
  inclusionRule  Json?
  durationRule   Json?
  status         String         @default("ACTIVA")

  standardActivityId String
  standardActivity   StandardActivity @relation(fields: [standardActivityId], references: [id], onDelete: Cascade)

  productivityRateId String?
  productivityRate   ProductivityRate? @relation(fields: [productivityRateId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([typologyId, code])
}

model AutomationSeedState {
  key          String   @id
  version      Int
  status       String   @default("OK")
  seededAt     DateTime @default(now())
  details      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProjectBudgetLine {
  id              String                  @id @default(cuid())
  name            String
  description     String?
  estimatedAmount Float                   @default(0)
  certifiedAmount Float                   @default(0)
  status          ProjectBudgetLineStatus @default(PENDING)

  startDate DateTime?
  endDate   DateTime?
  order     Int       @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  certificationLines ProjectCertificationLine[]
  expenses           ProjectExpense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ProjectBudgetLineStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ProjectExpense {
  id          String             @id @default(cuid())
  description String
  amount      Float
  paidAmount  Float              @default(0)
  date        DateTime           @default(now())
  dueDate     DateTime?
  category    String? // Materiales, Mano de Obra, Subcontrata, etc.
  type        ProjectExpenseType @default(DIRECT_BUDGET)
  status      String             @default("PENDIENTE") // PENDIENTE, PARCIAL, PAGADO

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  budgetLineId String?
  budgetLine   ProjectBudgetLine? @relation(fields: [budgetLineId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  movements Movement[]
}

enum ProjectExpenseType {
  DIRECT_BUDGET // Vinculado a una partida específica
  DIRECT_PROJECT // Directo de obra pero sin partida (herramientas, transporte, etc.)
  LABOR // Mano de obra propia imputada directamente
}

// Gastos generales de la empresa (Estructura) - Phase 40
model CompanyExpense {
  id          String    @id @default(cuid())
  description String
  amount      Float
  paidAmount  Float     @default(0)
  date        DateTime  @default(now())
  dueDate     DateTime?
  category    String // Alquiler, Gestoría, Seguros, Oficina, etc.
  status      String    @default("PENDIENTE") // PENDIENTE, PARCIAL, PAGADO

  userId String
  user   User   @relation(fields: [userId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  imputations ImputedExpense[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  movements Movement[]
}

// Imputación de gastos de estructura a obras específicas - Phase 40
model ImputedExpense {
  id     String   @id @default(cuid())
  amount Float
  date   DateTime @default(now())
  notes  String?

  companyExpenseId String
  companyExpense   CompanyExpense @relation(fields: [companyExpenseId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Project Certification (Certificaciones de Obra)
model ProjectCertification {
  id     String   @id @default(cuid())
  number String // e.g., CERT-001
  date   DateTime @default(now())
  period String? // e.g., "Marzo 2026"
  status String   @default("DRAFT") // DRAFT, ISSUED

  totalAmount     Float @default(0) // Bruto certificado en este periodo
  retentionAmount Float @default(0) // Retención (ej. 5%)
  netAmount       Float @default(0) // Líquido a percibir

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  lines     ProjectCertificationLine[]
  invoiceId String?
  invoice   Invoice?                   @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectCertificationLine {
  id              String               @id @default(cuid())
  certificationId String
  certification   ProjectCertification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  budgetLineId String
  budgetLine   ProjectBudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  previousAmount Float @default(0) // Acumulado anterior
  currentAmount  Float @default(0) // Certificado ahora
  totalToDate    Float @default(0) // Acumulado total (Origen)
  percentage     Float @default(0) // % de avance total

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 34: Site Journal & Documentation
model ProjectLog {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  content   String   @db.Text
  weather   String? // Sunny, Rainy, Cloudy, etc.
  incidents String?  @db.Text

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  photos ProjectPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectPhoto {
  id      String  @id @default(cuid())
  url     String
  caption String?

  logId String
  log   ProjectLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ProjectDocument {
  id       String  @id @default(cuid())
  name     String
  url      String
  fileType String? // PDF, Image, etc.
  category String  @default("OTROS") // PLANO, CONTRATO, SEGURO, OTROS

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 44: Real Treasury & Cash Flow
model Movement {
  id          String           @id @default(cuid())
  amount      Float
  date        DateTime         @default(now())
  method      String           @default("TRANSFERENCIA") // EFECTIVO, TRANSFERENCIA, TARJETA, BIZUM, OTROS
  description String
  type        MovementType // ENTRY (Inflow), EXIT (Outflow)
  category    MovementCategory

  // Relations
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  projectExpenseId String?
  projectExpense   ProjectExpense? @relation(fields: [projectExpenseId], references: [id])

  companyExpenseId String?
  companyExpense   CompanyExpense? @relation(fields: [companyExpenseId], references: [id])

  // States specific to ENTRY (Anticipos, etc.)
  isFacturado Boolean @default(false)

  imputations MovementImputation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MovementImputation {
  id     String   @id @default(cuid())
  amount Float
  date   DateTime @default(now())

  movementId String
  movement   Movement @relation(fields: [movementId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum MovementType {
  ENTRY
  EXIT
}

enum MovementCategory {
  ANTICIPO // Entry: Money received before invoice
  COBRO_FACTURA // Entry: Money received for an invoice
  INGRESO_DIRECTO // Entry: Money received without invoice (Direct income)
  PAGO_PROVEEDOR // Exit: Payment to supplier/subcontractor
  NOMINA // Exit: Salary payment
  ESTRUCTURA // Exit: Company general expense
  OTROS // Both: Internal transfers, loans, etc.
}

// Phase 47: Project Base Configuration
model ProjectCalendar {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  workingDays    String  @default("[\"Lunes\",\"Martes\",\"Miércoles\",\"Jueves\",\"Viernes\"]")
  workHours      String  @default("08:00-18:00")
  worksSaturdays Boolean @default(false)
  worksHolidays  Boolean @default(false)
  bufferDays     Int     @default(0)
  timeCriteria   String  @default("LABORABLES") // NATURALES, LABORABLES

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectMilestone {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name         String
  description  String?
  targetDate   DateTime
  priority     String   @default("MEDIA") // ALTA, MEDIA, BAJA, CRITICA
  manager      String?
  status       String   @default("PENDIENTE") // PENDIENTE, ALCANZADO, RETRASADO
  observations String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectConstraint {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title                String
  type                 String // LICENCIA, SUMINISTRO, CLIENTE, ENTORNO, NORMATIVA, OTROS
  description          String    @db.Text
  impact               String    @default("MEDIO") // ALTO, MEDIO, BAJO, BLOQUEANTE  
  priority             String    @default("MEDIA") // ALTA, MEDIA, BAJA, CRITICA
  manager              String?
  status               String    @default("ABIERTA") // ABIERTA, EN_PROCESO, RESUELTA
  targetResolutionDate DateTime?
  comments             String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Phase 48: Estructura de ubicaciones y zonas
model ProjectLocation {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Recursividad
  parentId        String?
  parent          ProjectLocation?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children        ProjectLocation[] @relation("LocationHierarchy")
  
  activities      ProjectActivity[]
  restrictions    Restriction[]
  supplies        ProjectSupply[]
  
  name            String
  code            String?
  type            String   // EDIFICIO, PLANTA, VIVIENDA, ZONA_COMUN, EXTERIOR, HABITACION, BANO, COCINA, etc.
  status          String   @default("ACTIVA") // PENDIENTE, ACTIVA, CERRADA, NO_APLICABLE, BLOQUEADA, FUERA_ALCANCE
  
  description     String?  @db.Text
  observations    String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 49: Estructura de Partidas (WBS)
model ProjectWBS {
  id              String       @id @default(cuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Jerarquía
  parentId        String?
  parent          ProjectWBS?  @relation("WBSHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children        ProjectWBS[] @relation("WBSHierarchy")
  
  activities      ProjectActivity[]
  restrictions    Restriction[]
  supplies        ProjectSupply[]
  
  code            String?      // Código jerárquico (Ej: 01.02.04)
  name            String       // Albañilería, Demoliciones, Encofrados...
  level           String       // CAPITULO, SUBCAPITULO, PARTIDA, PAQUETE_TRABAJO
  status          String       @default("PENDIENTE") // PENDIENTE, EN_PREPARACION, ACTIVA, CERRADA, NO_APLICABLE, BLOQUEADA
  
  description     String?      @db.Text
  observations    String?      @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 50: Biblioteca de Actividades Estándar
model StandardActivity {
  id              String   @id @default(cuid())
  
  // Datos Generales
  code            String?  @unique // Ej: ALB-01
  name            String
  category        String   // ALBANILERIA, DEMOLICIONES, INSTALACIONES, etc.
  description     String?  @db.Text
  observations    String?  @db.Text
  status          String   @default("ACTIVA") // BORRADOR, REVISION, ACTIVA, ARCHIVADA, OBSOLETA
  
  // Atributos y Banderas Funcionales
  defaultUnit         String?  @default("ud") // m2, m3, ud, ml...
  requiresQuantity    Boolean  @default(false)
  requiresLocation    Boolean  @default(true)
  requiresManager     Boolean  @default(false)
  requiresCrew        Boolean  @default(false)
  
  canBeInSchedule     Boolean  @default(true)
  canBeInLookahead    Boolean  @default(true)
  canBeInWeeklyPlan   Boolean  @default(true)
  
  requiresInspection  Boolean  @default(false)
  relatedToPurchases  Boolean  @default(false)
  generatesWait       Boolean  @default(false) // Fraguado, secado...
  actsAsMilestone     Boolean  @default(false)
  allowsRepetition    Boolean  @default(true) // Puede ejecutarse repetidamente
  
  productivityRates   ProductivityRate[]
  projectActivities   ProjectActivity[]
  costItemTemplates   TypologyCostItem[]
  typologyTemplates   TypologyActivityTemplate[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 51: Banco de Rendimientos
model ProductivityRate {
  id              String   @id @default(cuid())
  
  name            String   // Ej: "Alicatado formato estándar interior"
  
  // Relación opcional con Actividades Estándar
  standardActivityId String?
  standardActivity   StandardActivity? @relation(fields: [standardActivityId], references: [id], onDelete: SetNull)
  
  // Datos Cuantitativos
  value           Float    // Ej: 25.5
  unit            String   // m2/día, ud/día, ml/día
  
  // Contexto y Clasificación
  category        String   // ALBANILERIA, DEMOLICIONES... (O hereda de Actividad)
  complexity      String   @default("MEDIA") // BAJA, MEDIA, ALTA
  workType        String   @default("GENERICO") // OBRA_NUEVA, REFORMA_PARCIAL, REHABILITACION_INTEGRAL
  locationType    String   @default("INTERIOR") // INTERIOR, EXTERIOR, MIXTO
  
  // Calidad del Dato
  confidenceLevel String   @default("TEORICO") // TEORICO, BASE_PLANIFICACION, HISTORICO_OBSERVADO, ESTIMADO
  status          String   @default("BORRADOR") // BORRADOR, EN_REVISION, VALIDADO, ACTIVO, OBSOLETO
  
  description     String?  @db.Text
  observations    String?  @db.Text

  costItemTemplates TypologyCostItem[]
  typologyTemplates TypologyActivityTemplate[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 52: Cronograma de Control
model ProjectActivity {
  id              String   @id @default(cuid())
  
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Conexiones Nucleares
  wbsId           String?
  wbs             ProjectWBS? @relation(fields: [wbsId], references: [id], onDelete: SetNull)
  
  locationId      String?
  location        ProjectLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  
  standardActivityId String?
  standardActivity StandardActivity? @relation(fields: [standardActivityId], references: [id], onDelete: SetNull)

  generationSource          String? // MASTER, FALLBACK, MANUAL
  originTypologyCode        String?
  originActivityTemplateCode String?
  originCostItemCode        String?
  originProductivityRateName String?
  
  // Datos Operativos
  name            String
  code            String?
  responsible     String?
  
  // Temporalidad Básica
  plannedDuration Float?   // En días
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  
  status          String   @default("PENDIENTE") 
  // Estados: PENDIENTE, PREPARADA, PLANIFICADA, EN_CURSO, PAUSADA, TERMINADA, BLOQUEADA, CANCELADA
  
  observations    String?  @db.Text
  
  // Relaciones direccionales de la red del cronograma
  predecessorLinks ActivityDependency[] @relation("SuccessorLinks")
  successorLinks   ActivityDependency[] @relation("PredecessorLinks")
  
  weeklyPlanInclusions WeeklyPlanActivity[]
  
  // PHASE 55: Seguimiento Real (Caché actual)
  realStatus      String?  @default("NO_INICIADA") // NO_INICIADA, EN_CURSO, PAUSADA, TERMINADA, CANCELADA
  realProgress    Float?   @default(0)
  realStartDate   DateTime?
  realEndDate     DateTime?

  progressLogs    ActivityProgressLog[]
  restrictions    Restriction[]
  supplies        ProjectSupply[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 53: Dependencias y Lógica del Cronograma
model ActivityDependency {
  id              String   @id @default(cuid())
  
  // Nodos de la red
  predecessorId   String
  predecessor     ProjectActivity @relation("SuccessorLinks", fields: [predecessorId], references: [id], onDelete: Cascade)
  
  successorId     String
  successor       ProjectActivity @relation("PredecessorLinks", fields: [successorId], references: [id], onDelete: Cascade)
  
  // Parámetros constructivos
  dependencyType  String   @default("FS") // FS, SS, FF, SF
  lagDays         Float    @default(0)    // Desfase en días (positivo=espera, negativo=solape)
  observations    String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([predecessorId, successorId])
}

// Phase 54: Plan Semanal (Compromiso Operativo)
model WeeklyPlan {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  weekName        String   // Ej: "2024-W42" o "Semana 42"
  startDate       DateTime?
  endDate         DateTime?
  
  generalManager  String?  // Responsable general de la semana
  status          String   @default("BORRADOR") // BORRADOR, ACTIVO, CERRADO
  observations    String?  @db.Text
  
  activities      WeeklyPlanActivity[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model WeeklyPlanActivity {
  id              String   @id @default(cuid())
  weeklyPlanId    String
  weeklyPlan      WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  
  projectActivityId String
  projectActivity   ProjectActivity @relation(fields: [projectActivityId], references: [id], onDelete: Cascade)
  
  // Datos tácticos
  priority        String   @default("NORMAL")     // CLAVE, IMPORTANTE, NORMAL, REMATE
  weeklyStatus    String   @default("PENDIENTE")  // PENDIENTE, EN_CURSO, COMPLETADA, NO_INICIADA, BLOQUEADA, CANCELADA, INCOMPLETA
  executionDays   String?  // Ej: "L, M, X"
  operationalNotes String? @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([weeklyPlanId, projectActivityId])
}

// Phase 55: Seguimiento Real Histórico
model ActivityProgressLog {
  id                String   @id @default(cuid())
  
  projectActivityId String
  projectActivity   ProjectActivity @relation(fields: [projectActivityId], references: [id], onDelete: Cascade)
  
  reportDate        DateTime @default(now())
  
  // Foto del momento
  statusReported    String
  progressReported  Float
  
  executionNotes    String?  @db.Text
  incidences        String?  @db.Text
  
  reporterName      String?
  
  createdAt         DateTime @default(now())
}

// Phase 56: Restricciones (Bloqueos operativos)
model Restriction {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title           String
  type            String   // COMPRAS, DECISIONES, DOCUMENTACION, PERMISOS, FRENTE, PERSONAL, OTROS
  description     String?  @db.Text
  
  // Vinculaciones opcionales (Dimensiones del bloqueo)
  projectActivityId String?
  projectActivity   ProjectActivity? @relation(fields: [projectActivityId], references: [id], onDelete: SetNull)
  
  locationId      String?
  location        ProjectLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  
  wbsId           String?
  wbs             ProjectWBS? @relation(fields: [wbsId], references: [id], onDelete: SetNull)
  
  // Gestión
  priority        String   @default("MEDIA")    // CRITICA, ALTA, MEDIA, MENOR
  status          String   @default("DETECTADA") // DETECTADA, EN_GESTION, RESUELTA, CERRADA
  responsible     String?  // Quién debe resolverlo
  targetDate      DateTime?
  
  impact          String?  // Bloquea arranque, bloquea avance, bloquea cierre
  observations    String?  @db.Text
  
  // Trazabilidad básica de resolución
  resolutionDate  DateTime?
  resolutionNotes String?  @db.Text
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 57: Compras Ligadas al Plazo (Suministros Operativos)
model ProjectSupply {
  id                String   @id @default(cuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  description       String   // Nombre del material/equipo
  category          String   // ACABADOS, ESTRUCTURA, INSTALACIONES, MOBILIARIO, etc.
  
  // Vinculación con Planificación
  projectActivityId  String?
  projectActivity    ProjectActivity? @relation(fields: [projectActivityId], references: [id], onDelete: SetNull)
  
  locationId        String?
  location          ProjectLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  
  wbsId             String?
  wbs               ProjectWBS? @relation(fields: [wbsId], references: [id], onDelete: SetNull)
  
  // Fechas Clave
  requiredOnSiteDate DateTime? // Cuándo debe estar en obra para ejecutar
  leadTimeDays      Int?      // Días de fabricación/entrega esperados (Plazo)
  orderDate         DateTime? // Fecha real en la que se pide/encarga
  
  // Gestión Operativa
  priority          String   @default("NORMAL")     // CRITICA, ALTA, NORMAL, APOYO
  status            String   @default("IDENTIFICADA") // IDENTIFICADA, PENDIENTE, PEDIDA, CONFIRMADA, EN_TRANSITO, RECIBIDA, RETRASADA
  responsible       String?  // Quién gestiona la compra
  
  quantity          Float?
  unit              String?
  
  observations      String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Phase 58: Baseline (Instantáneas del Plan)
model ProjectBaseline {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  name            String   // Ej: Baseline Contractual V1
  description     String?
  responsible     String?
  status          String   @default("VIGENTE") // VIGENTE, ARCHIVADA, BORRADOR
  
  // Snapshot de las actividades en este momento
  snapshotData    Json     // Guardaremos un dump de las fechas de actividades para comparativa rápida
  
  createdAt       DateTime @default(now())
}

// Phase 58: Control de Cambios (Modificaciones Formales)
model ProjectChangeRequest {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  reason          String   // ALCANCE, TECNICO, SUMINISTRO, CLIENTE, etc.
  impact          String?  // PLAZO, COSTE, SECUENCIA
  priority        String   @default("MEDIA")
  
  status          String   @default("PROPUESTO") // PROPUESTO, REVISADO, APROBADO, IMPLEMENTADO, RECHAZADO
  requestedDate   DateTime @default(now())
  approvedDate    DateTime?
  responsible     String?
  
  observations    String?  @db.Text
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}


