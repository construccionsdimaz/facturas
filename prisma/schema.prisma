// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL_NON_POOLING")
}

// User represents the company/owner of the app (you and your team)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      String   @default("ADMIN") // ADMIN, ACCOUNTANT, etc
  
  // Company Profile Settings
  companyName    String?
  companyAddress String?
  companyCity    String?
  companyZip     String?
  companyProvince String?
  companyTaxId   String?
  companyLogo    String? 
  logoZoom       Float    @default(1)
  logoX          Float    @default(0)
  logoY          Float    @default(0)
  paymentMethod  String?
  bankAccount    String?
  dataProtection String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  clients   Client[] // The clients that belong to this user
  invoices  Invoice[]
  estimates Estimate[]
  projects  Project[]
}

// Client represents the people/companies you are billing
model Client {
  id        String   @id @default(cuid())
  name      String
  email     String?
  address   String?
  phone     String?
  taxId     String?  // NIF/CIF/DNI/NIE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  invoices  Invoice[]
  estimates Estimate[]
  projects  Project[]
}

// Invoice record
model Invoice {
  id          String   @id @default(cuid())
  number      String   @unique // INV-2026-001
  issueDate   DateTime @default(now())
  dueDate     DateTime?
  status      String   @default("DRAFT") // DRAFT, PENDING, PAID, OVERDUE
  
  subtotal    Float    @default(0)
  taxRate     Float    @default(21.0)
  taxAmount   Float    @default(0)
  total       Float    @default(0)
  
  currency    String   @default("EUR")
  language    String   @default("ES") // ES, CA, EN
  notes       String?
  paymentMethod String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  
  items       InvoiceItem[]
}

// Individual items (concepts) within an invoice
model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  price       Float    @default(0)
  
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// Estimate record (Presupuesto)
model Estimate {
  id          String   @id @default(cuid())
  number      String   @unique // PRE-2026-001
  issueDate   DateTime @default(now())
  validUntil  DateTime?
  status      String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, CONVERTED
  
  subtotal    Float    @default(0)
  taxRate     Float    @default(21.0)
  taxAmount   Float    @default(0)
  total       Float    @default(0)
  
  currency    String   @default("EUR")
  language    String   @default("ES") // ES, CA, EN
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  
  items       EstimateItem[]
  
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  
  invoiceId   String?  @unique // Link to the invoice if converted
}

// Individual items (concepts) within an estimate
model EstimateItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int      @default(1)
  price       Float    @default(0)
  
  estimateId  String
  estimate    Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
}

// Project/Work record (Obra)
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  address     String?
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  
  invoices    Invoice[]
  estimates   Estimate[]
  budgetLines ProjectBudgetLine[]
  expenses    ProjectExpense[]
}

model ProjectBudgetLine {
...
  updatedAt       DateTime @updatedAt
}

model ProjectExpense {
  id              String   @id @default(cuid())
  description     String
  amount          Float
  date            DateTime @default(now())
  category        String?  // Materiales, Mano de Obra, Subcontrata, etc.
  
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
